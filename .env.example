# =============================================================================
# SciLab Web — environment template
# Copy to `.env.local` for local Next.js (`pnpm dev` / `npm run dev`).
# Do not commit real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# API routing (browser → same-origin /backend → upstream)
# ---------------------------------------------------------------------------

# `public` | `local`
# - public → rewrite /backend → SCILAB_API_ORIGIN (or https://scilab-api.epsilon.io.vn)
# - local  → rewrite /backend → NEXT_PUBLIC_LOCAL_API_URL (or http://localhost:6003)
NEXT_PUBLIC_API_DATA_SOURCE=public

# Browser API base path (keep /backend unless you know you need otherwise)
NEXT_PUBLIC_API_URL=/backend

# Server-side upstream for Next rewrites + auth BFF (wins over public default)
SCILAB_API_ORIGIN=https://scilab-api.epsilon.io.vn

# Only used when NEXT_PUBLIC_API_DATA_SOURCE=local
# NEXT_PUBLIC_LOCAL_API_URL=http://localhost:6003

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------

# Related works graph on article detail:
# - public-api (default) → GET /academic/graphs/article/:id
# - connect-papers → build graph from cited articles already in the catalog
NEXT_PUBLIC_RELATED_WORKS_GRAPH_SOURCE=public-api

# ---------------------------------------------------------------------------
# Local quick-start examples (uncomment one profile)
# ---------------------------------------------------------------------------

# --- Talk to deployed epsilon API ---
# NEXT_PUBLIC_API_DATA_SOURCE=public
# SCILAB_API_ORIGIN=https://scilab-api.epsilon.io.vn
# NEXT_PUBLIC_API_URL=/backend
# NEXT_PUBLIC_RELATED_WORKS_GRAPH_SOURCE=public-api

# --- Talk to local Nest/Docker API on :6003 ---
# NEXT_PUBLIC_API_DATA_SOURCE=local
# NEXT_PUBLIC_LOCAL_API_URL=http://localhost:6003
# NEXT_PUBLIC_API_URL=/backend
# NEXT_PUBLIC_RELATED_WORKS_GRAPH_SOURCE=public-api

# Backend data source for the web app: `public` | `local`
# - public → proxy /backend → https://scilab-api.epsilon.io.vn
# - local  → proxy /backend → http://localhost:6003
NEXT_PUBLIC_API_DATA_SOURCE=public

# Browser always calls same-origin /backend (see next.config.ts rewrites)
NEXT_PUBLIC_API_URL=/backend

# Optional when NEXT_PUBLIC_API_DATA_SOURCE=local
# NEXT_PUBLIC_LOCAL_API_URL=http://localhost:6003

# Rewrite target when data source is public (auth BFF uses this too)
# SCILAB_API_ORIGIN=https://scilab-api.epsilon.io.vn
